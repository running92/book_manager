# Same-origin deployment through Flask/Nginx:
VITE_API_BASE_URL=/api
VITE_ASSET_BASE_URL=

# Development proxy target. Set this to your backend server address when running npm run dev.
VITE_DEV_API_TARGET=http://<server-ip>:5000

# If frontend and backend are deployed on different domains, build with:
# VITE_API_BASE_URL=https://api.example.com/api
# VITE_ASSET_BASE_URL=https://api.example.com
